algoritmo "Laços de repetiçao"
var
   mensagem: caracter

   inicio
     escreva("Mensagem: ")
     leia(mensagem)
     enquanto mensagem <> "s" faca
     escreva(mensagem)
     escreva(" Próxima mensagem [s para sair]: ")
     leia(mensagem)
     fimenquanto
     escreva(" Saiu do laço!")
     fimalgoritmo